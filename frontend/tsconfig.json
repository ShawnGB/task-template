{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["./app/*"]
    }
  },
  "include": ["app", ".react-router/types/**/*", "../packages/shared/src/globals.d.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
